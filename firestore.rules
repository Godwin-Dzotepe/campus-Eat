rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && role() == 'admin';
    }

    function isVendor() {
      return signedIn() && role() == 'vendor';
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /foods/{foodId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && (request.resource.data.vendorId == request.auth.uid || isAdmin());
      allow update, delete: if signedIn()
        && (resource.data.vendorId == request.auth.uid || isAdmin());
    }

    match /orders/{orderId} {
      allow read: if signedIn()
        && (resource.data.buyerId == request.auth.uid
          || resource.data.vendorId == request.auth.uid
          || isAdmin());
      allow create: if signedIn();
      allow update: if signedIn()
        && (resource.data.vendorId == request.auth.uid
          || resource.data.buyerId == request.auth.uid
          || isAdmin());
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.buyerId == request.auth.uid;
    }

    match /categories/{catId} {
      allow read: if signedIn();
      allow create: if signedIn() && (isAdmin() || isVendor());
      allow update, delete: if isAdmin();
    }
  }
}
